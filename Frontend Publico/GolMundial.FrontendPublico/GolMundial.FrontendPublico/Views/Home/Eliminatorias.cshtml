@model List<Partido>

@{
    ViewData["Title"] = "Eliminatorias";

    var ordenFases = new[] { "DIECISEISAVOS", "OCTAVOS", "CUARTOS", "SEMIFINAL", "FINAL" };

    var titulos = new Dictionary<string, string>
    {
        ["DIECISEISAVOS"] = "16avos de final",
        ["OCTAVOS"] = "Octavos de final",
        ["CUARTOS"] = "Cuartos de final",
        ["SEMIFINAL"] = "Semifinal",
        ["FINAL"] = "Final",
        ["TERCER_PUESTO"] = "3.º / 4.º puesto"
    };

    var tercerPuesto = Model
        .Where(p => p.FaseCodigo == "TERCER_PUESTO")
        .OrderBy(p => p.NumeroPartidoFifa)
        .ToList();
}

<h2 class="mb-4">Fase eliminatoria</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Todavía no hay partidos de eliminatorias cargados. Los cruces se definen
        cuando termine la fase de grupos.
    </div>
}
else
{
    <div class="bracket">
        @foreach (var codigo in ordenFases)
        {
            var partidos = Model
                .Where(p => p.FaseCodigo == codigo)
                .OrderBy(p => p.NumeroPartidoFifa)
                .ToList();

            var mostrarTercero = codigo == "FINAL" && tercerPuesto.Any();

            if (!partidos.Any() && !mostrarTercero)
            {
                continue;
            }

            <div class="bracket__fase @(codigo == "FINAL" ? "bracket__fase--final" : "")">
                <div class="bracket__titulo">@titulos[codigo]</div>
                <div class="bracket__partidos">
                    @foreach (var partido in partidos)
                    {
                        <partial name="_LlaveCard" model="partido" />
                    }

                    @if (mostrarTercero)
                    {
                        <div class="bracket__tercero">
                            <div class="bracket__subtitulo">@titulos["TERCER_PUESTO"]</div>
                            @foreach (var partido in tercerPuesto)
                            {
                                <partial name="_LlaveCard" model="partido" />
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}