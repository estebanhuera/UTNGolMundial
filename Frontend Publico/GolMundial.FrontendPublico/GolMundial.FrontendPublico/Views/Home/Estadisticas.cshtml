@model List<EstadisticaSeleccion>

@{
    ViewData["Title"] = "Estadísticas";
}

<h2 class="mb-4">Estadísticas por Selección</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">No hay estadísticas cargadas.</div>
}
else
{
    <div class="tabla-card">
        <div class="tabla-card__titulo">Todas las selecciones</div>
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Selección</th>
                    <th>Confederación</th>
                    <th class="text-center">PJ</th>
                    <th class="text-center">G</th>
                    <th class="text-center">E</th>
                    <th class="text-center">P</th>
                    <th class="text-center">GF</th>
                    <th class="text-center">GC</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var est in Model)
                {
                    <tr>
                        <td>
                            <partial name="_Bandera" model="est.CodigoFifa" />
                            @est.Nombre <span class="text-muted small">(@est.CodigoFifa)</span>
                            @if (est.EsAnfitrion)
                            {
                                <span class="badge bg-warning text-dark">Anfitrión</span>
                            }
                        </td>
                        <td>@est.Confederacion</td>
                        <td class="text-center">@est.PartidosJugados</td>
                        <td class="text-center">@est.Ganados</td>
                        <td class="text-center">@est.Empatados</td>
                        <td class="text-center">@est.Perdidos</td>
                        <td class="text-center">@est.GolesFavor</td>
                        <td class="text-center">@est.GolesContra</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}