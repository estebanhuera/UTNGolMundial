@model List<Partido>

@{
    ViewData["Title"] = "Calendario";
}

<h2 class="mb-4">Calendario del Mundial 2026</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">No hay partidos cargados.</div>
}
else
{
    @foreach (var grupo in Model.GroupBy(p => p.GrupoCodigo).OrderBy(g => g.Key))
    {
        <h4 class="mt-4 mb-3">Grupo @grupo.Key</h4>

        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Fecha</th>
                    <th>Partido</th>
                    <th>Sede</th>
                    <th>Estado</th>
                    <th>Resultado</th>
                    <th>Predicción</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var partido in grupo)
                {
                    <tr>
                        <td>@partido.FechaHora.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <partial name="_Bandera" model="partido.CodigoFifaLocal" />
                            @partido.EquipoLocal
                            <span class="text-muted">vs</span>
                            <partial name="_Bandera" model="partido.CodigoFifaVisitante" />
                            @partido.EquipoVisitante
                        </td>
                        <td>@partido.Sede</td>
                        <td>
                            @if (partido.Estado == "FINALIZADO")
                            {
                                <span class="badge bg-secondary">Finalizado</span>
                            }
                            else if (partido.Estado == "EN_JUEGO")
                            {
                                <span class="badge bg-danger">En juego</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Programado</span>
                            }
                        </td>
                        <td>
                            @if (partido.Estado == "FINALIZADO")
                            {
                                @($"{partido.GolesLocal} - {partido.GolesVisitante}")
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </td>
                        <td>
                            @if (partido.Estado == "PROGRAMADO")
                            {
                                <a class="btn btn-sm text-white fw-bold"
                                       style="background-color:#0b3d2e;"
                                       asp-controller="Predicciones" asp-action="Nueva"
                                       asp-route-partidoId="@partido.Id">
                                    Predecir
                                </a>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}