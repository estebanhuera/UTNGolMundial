@using System.Globalization
@model List<Partido>

@{
    ViewData["Title"] = "Calendario";
    var cultura = new CultureInfo("es-EC");
}

<h2 class="mb-4">Calendario del Mundial 2026</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">No hay partidos cargados.</div>
}
else
{
    @foreach (var grupo in Model.GroupBy(p => p.GrupoCodigo).OrderBy(g => g.Key))
    {
        <h4 class="mt-4 mb-3">Grupo @grupo.Key</h4>

        <div class="partidos-grid">
            @foreach (var partido in grupo)
            {
                var fecha = partido.FechaHora.ToLocalTime();

                <div class="partido-card">
                    <div class="partido-card__top">
                        <span>@fecha.ToString("ddd d/M", cultura).ToUpper(cultura)</span>
                        <span>
                            @switch (partido.Estado)
                            {
                                case "FINALIZADO":
                                    @:FINALIZADO
                                    break;
                                case "EN_JUEGO":
                                    @:EN JUEGO
                                    break;
                                default:
                                    @:PROGRAMADO
                                    break;
                            }
                        </span>
                    </div>

                    <div class="partido-card__cuerpo">
                        <div class="partido-card__equipo">
                            <partial name="_Bandera" model="partido.CodigoFifaLocal" />
                            <div class="partido-card__nombre">@partido.EquipoLocal</div>
                        </div>

                        @if (partido.Estado == "FINALIZADO")
                        {
                            <div class="partido-card__marcador">
                                @partido.GolesLocal &ndash; @partido.GolesVisitante
                            </div>
                        }
                        else
                        {
                            <div class="partido-card__hora">@fecha.ToString("HH:mm")</div>
                        }

                        <div class="partido-card__equipo">
                            <partial name="_Bandera" model="partido.CodigoFifaVisitante" />
                            <div class="partido-card__nombre">@partido.EquipoVisitante</div>
                        </div>
                    </div>

                    @if (partido.Estado == "PROGRAMADO")
                    {
                        <div class="partido-card__accion">
                            <a class="btn btn-sm text-white fw-bold w-100"
                                   style="background-color:#0b3d2e;"
                                   asp-controller="Predicciones" asp-action="Nueva"
                                   asp-route-partidoId="@partido.Id">
                                Predecir
                            </a>
                        </div>
                    }
                </div>
            }
        </div>
    }
}