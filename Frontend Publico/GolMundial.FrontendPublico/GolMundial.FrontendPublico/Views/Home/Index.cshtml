@model List<GolMundial.FrontendPublico.Models.Partido>

@{
    ViewData["Title"] = "Calendario";
}

<h2 class="mb-4">Calendario del Mundial 2026</h2>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Fecha</th>
            <th>Partido</th>
            <th>Sede</th>
            <th>Fase</th>
            <th>Estado</th>
            <th>Resultado</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var partido in Model)
        {
            <tr>
                <td>@partido.FechaHora.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                <td>@partido.EquipoLocal vs @partido.EquipoVisitante</td>
                <td>@partido.Sede</td>
                <td>@partido.Fase</td>
                <td>
                    @if (partido.Estado == "FINALIZADO")
                    {
                        <span class="badge bg-secondary">Finalizado</span>
                    }
                    else if (partido.Estado == "EN_JUEGO")
                    {
                        <span class="badge bg-danger">En juego</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Programado</span>
                    }
                </td>
                <td>
                    @if (partido.GolesLocal.HasValue)
                    {
                        @($"{partido.GolesLocal} - {partido.GolesVisitante}")
                    }
                    else
                    {
                        <span>-</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>