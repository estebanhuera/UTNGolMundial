@model List<Posicion>

@{
    ViewData["Title"] = "Posiciones";
}

<h2 class="mb-4">Tabla de Posiciones</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">No hay posiciones cargadas.</div>
}
else
{
    @foreach (var grupo in Model.GroupBy(p => p.GrupoCodigo).OrderBy(g => g.Key))
    {
        <div class="tabla-card">
            <div class="tabla-card__titulo">Grupo @grupo.Key</div>
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Selección</th>
                        <th class="text-center">PJ</th>
                        <th class="text-center">PG</th>
                        <th class="text-center">PE</th>
                        <th class="text-center">PP</th>
                        <th class="text-center">GF</th>
                        <th class="text-center">GC</th>
                        <th class="text-center">Dif</th>
                        <th class="text-end">Pts</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pos in grupo.OrderByDescending(p => p.Puntos).ThenByDescending(p => p.Dif))
                    {
                        <tr>
                            <td>
                                <partial name="_Bandera" model="pos.CodigoFifa" />
                                @pos.Nombre <span class="text-muted small">(@pos.CodigoFifa)</span>
                            </td>
                            <td class="text-center">@pos.Pj</td>
                            <td class="text-center">@pos.Pg</td>
                            <td class="text-center">@pos.Pe</td>
                            <td class="text-center">@pos.Pp</td>
                            <td class="text-center">@pos.Gf</td>
                            <td class="text-center">@pos.Gc</td>
                            <td class="text-center">@pos.Dif</td>
                            <td class="text-end fw-bold">@pos.Puntos</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}